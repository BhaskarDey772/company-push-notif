{
  "name": "@bhaskardey772/push-notif-backend",
  "version": "1.2.0",
  "description": "Backend helper for Firebase Cloud Messaging — send push notifications to devices, topics, and conditions without boilerplate",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./slim": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.slim.js",
      "default": "./dist/index.slim.js"
    }
  },
  "peerDependencies": {
    "firebase-admin": ">=11.0.0"
  },
  "peerDependenciesMeta": {
    "firebase-admin": { "optional": true }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "rm -rf dist && node build.mjs",
    "dev": "tsc --watch",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "firebase",
    "firebase-admin",
    "fcm",
    "push-notification",
    "cloud-messaging",
    "node",
    "typescript"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/BhaskarDey772/company-push-notif",
    "directory": "packages/backend"
  },
  "homepage": "https://github.com/BhaskarDey772/company-push-notif#readme",
  "bugs": {
    "url": "https://github.com/BhaskarDey772/company-push-notif/issues"
  },
  "engines": {
    "node": ">=16"
  },
  "devDependencies": {
    "esbuild": "^0.25.12",
    "firebase-admin": "^12.7.0",
    "typescript": "~5.4.0"
  }
}
