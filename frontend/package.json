{
  "name": "@bhaskardey772/push-notif-frontend",
  "version": "1.0.4",
  "description": "Frontend helper for Firebase Cloud Messaging — request permission, get FCM tokens, and handle push notifications without boilerplate",
  "main": "src/index.js",
  "module": "src/index.js",
  "types": "src/index.d.ts",
  "exports": {
    ".": {
      "import": "./src/index.js",
      "types": "./src/index.d.ts"
    }
  },
  "files": [
    "src",
    "firebase-messaging-sw.js",
    "README.md"
  ],
  "sideEffects": false,
  "scripts": {
    "prepublishOnly": "node -e \"require('fs').existsSync('src/index.js') || process.exit(1)\""
  },
  "keywords": [
    "firebase",
    "fcm",
    "push-notification",
    "cloud-messaging",
    "browser",
    "service-worker",
    "typescript"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/BhaskarDey772/company-push-notif",
    "directory": "packages/frontend"
  },
  "homepage": "https://github.com/BhaskarDey772/company-push-notif#readme",
  "bugs": {
    "url": "https://github.com/BhaskarDey772/company-push-notif/issues"
  },
  "engines": {
    "node": ">=16"
  },
  "peerDependencies": {
    "firebase": ">=10.0.0"
  },
  "devDependencies": {
    "firebase": "^10.0.0"
  }
}
