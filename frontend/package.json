{
  "name": "@bhaskardey772/fcm-frontend",
  "version": "1.0.0",
  "description": "Frontend helper for Firebase Cloud Messaging — request permission, get FCM tokens, and handle push notifications without boilerplate",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "src/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./src/index.d.ts"
    },
    "./slim": {
      "import": "./dist/index.slim.js",
      "types": "./src/index.d.ts"
    }
  },
  "peerDependencies": {
    "firebase": ">=10.0.0"
  },
  "peerDependenciesMeta": {
    "firebase": {
      "optional": true
    }
  },
  "files": [
    "dist",
    "src/index.d.ts",
    "firebase-messaging-sw.js",
    "README.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "rm -rf dist && node build.mjs",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "firebase",
    "fcm",
    "push-notification",
    "cloud-messaging",
    "browser",
    "service-worker",
    "typescript"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/BhaskarDey772/company-push-notif",
    "directory": "packages/frontend"
  },
  "homepage": "https://github.com/BhaskarDey772/company-push-notif#readme",
  "bugs": {
    "url": "https://github.com/BhaskarDey772/company-push-notif/issues"
  },
  "engines": {
    "node": ">=16"
  },
  "devDependencies": {
    "esbuild": "^0.25.12",
    "firebase": "^11.0.0"
  }
}
